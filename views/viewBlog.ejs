<!DOCTYPE html>
<html lang="en">
<head>
    <%- include('partials/head.ejs') %>
    <title><%= blog.title %></title>
</head>

<body class="bg-light">

    <%- include('partials/nav.ejs') %>

    <div class="container py-5">

        <div class="card border-0 shadow-sm">
            <div class="ratio ratio-21x9 rounded-top-4 overflow-hidden">
                <img
                    src="<%= blog.coverImage %>"
                    class="w-100 h-100 object-fit-cover"
                    alt="<%= blog.title %>"
                >
            </div>

           
            <div class="card-body p-5">

                <h1 class="display-4 fw-bold mb-3">
                    <%= blog.title %>
                </h1>
                <a style="display: inline-block;">
                    <span class="d-flex align-items-center gap-3">

                <a
    href="/user/profile/<%= blog.createdBy %>"
    class="text-decoration-none d-inline-flex align-items-center gap-2"
>

        <img
            src="<%= curr.profileUrl %>"
            alt="Profile"
            class="rounded-circle"
            style="width:40px; height:40px; object-fit:cover;"
        >

        <div>
            <div class="text-secondary small">
                Published by
            </div>

            <div class="fw-semibold text-dark">
                <%= curr.fullName %>
            </div>
        </div>

        </a>
            </span>
                </a>
                <div>
                    <div class="d-flex align-items-center gap-3 mb-4">
                <h2 class="mb-0">Comments(<%= n %>)</h2>
                    <a href="/blog/comment/<%= blog._id %>" style="display: inline-block;">
                        <img src="https://res.cloudinary.com/dwiesfgni/image/upload/v1781207712/chat-bubble_12309678_xh3rhc.png " style="width: 45px; height: 45px;" alt="View comments">
                    </a>
                    
                </div>
                    <div>
                        <form action="/blog/comment/<%=blog._id%>" method="POST">

                            <div class="input-group mt-4">

                                <input
                                    type="text"
                                    name="content"
                                    class="form-control"
                                    placeholder="Write a comment..."
                                    required
                                >

                                <button
                                    type="submit"
                                    class="btn btn-primary"
                                >
                                    Comment
                                </button>

                            </div>

                        </form>
                        <div>
                            
                        </div>
                    </div>
                    
                    
                </div>
                <% if ((user && blog.createdBy.toString() === user._id.toString())||(user&&user.role==='ADMIN')) { %>

                        <a
                            href="/blog/edit-Blog/<%= blog._id %>"
                            class="btn btn-warning"
                            style="margin: 10px;"
                        >
                            Edit Blog
                        </a>
                        <a
                                        href="/blog/delete/<%= blog._id %>"
                                        class="btn btn-danger flex-fill"
                                    >
                                        delete
                                    </a>

                    <% } %>
                
                <hr class="mb-4">

                <div class="bg-light rounded-4 p-4 mt-4">

                <div class="fs-5 lh-lg text-dark">
                    <%= blog.body %>
                </div>

                </div>

            </div>

        </div>

    </div>

    <%- include('partials/scripts.ejs') %>

</body>
</html>